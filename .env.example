# ── Supabase (requerido) ────────────────────────────────────────────────────
# Copia este archivo a ".env" y rellena los valores de tu proyecto Supabase.
# Los encuentras en: Supabase → Project Settings → API.
# Solo las variables con prefijo VITE_ se exponen al cliente (es seguro: la
# anon key es pública por diseño y los datos se protegen con RLS, ver supabase/schema.sql).
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_de_supabase_aqui

# ── Funciones serverless (opcional, solo en Vercel) ─────────────────────────
# Estas variables NO llevan prefijo VITE_: viven solo en el servidor (api/) y
# nunca se envían al navegador. La app web funciona sin ellas; solo afectan a
# las funciones de /api.

# Buzón de Web3Forms al que /api/feedback reenvía los mensajes del formulario
# de feedback. Crea una "access key" gratis en https://web3forms.com.
WEB3FORMS_ACCESS_KEY=tu_access_key_de_web3forms

# Patrones extra a ignorar al parsear estados de cuenta en /api/parse-pdf
# (p. ej. el nombre del titular o su email, que aparecen en el PDF). Lista
# separada por comas. Se mantiene fuera del código para no versionar PII.
# STATEMENT_SKIP_PATTERNS=NOMBRE APELLIDO,correo@ejemplo.com
