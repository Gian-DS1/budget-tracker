# ── Supabase (requerido) ────────────────────────────────────────────────────
# Copia este archivo a ".env" y rellena los valores de tu proyecto Supabase.
# Los encuentras en: Supabase → Project Settings → API.
# Solo las variables con prefijo VITE_ se exponen al cliente (es seguro: la
# anon key es pública por diseño y los datos se protegen con RLS, ver supabase/schema.sql).
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_de_supabase_aqui

# ── Tasa del dólar vía Banco Popular (opcional) ──────────────────────────────
# API key de TasaReal para obtener la tasa de VENTA real del Banco Popular.
# Es server-only (SIN prefijo VITE_): nunca llega al bundle del cliente.
#   - En producción: configúrala en Vercel → Project Settings → Environment
#     Variables (la usa la función serverless api/rate.js).
#   - En local: ponla aquí en tu .env para ver la tasa real en `npm run dev`
#     (la usa el middleware del dev server, ver vite.config.js).
# Si no la configuras, la app usa la tasa de mercado global como respaldo.
TASAREAL_API_KEY=tu_api_key_de_tasareal
